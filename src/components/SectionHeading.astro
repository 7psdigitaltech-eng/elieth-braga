---
interface Props {
  eyebrow: string;
  title: string;
  id?: string;
  description?: string;
}

const { eyebrow, title, id, description } = Astro.props;
---

<div class="section-heading">
  <p class="section-eyebrow">{eyebrow}</p>
  <h2 id={id}>{title}</h2>
  {description && <p class="section-description">{description}</p>}
</div>
