---
import SectionHeading from "./SectionHeading.astro";
import { siteContent } from "../content/site";
---

<section class="page-section social-section" id="conteudos" aria-labelledby="conteudos-title">
  <SectionHeading
    eyebrow={siteContent.socialSection.eyebrow}
    title={siteContent.socialSection.title}
    id="conteudos-title"
    description={siteContent.socialSection.description}
  />
  <div class="social-grid">
    <article class="social-card">
      <span>Instagram</span>
      <h3>{siteContent.social.instagramHandle}</h3>
      <a class="button button-secondary" href={siteContent.instagramUrl} rel="me noopener noreferrer" target="_blank">
        {siteContent.ctas.instagram}
      </a>
    </article>
    <article class="social-card">
      <span>Facebook</span>
      <h3>{siteContent.social.facebookLabel}</h3>
      <a class="button button-secondary" href={siteContent.facebookUrl} rel="me noopener noreferrer" target="_blank">
        {siteContent.ctas.facebook}
      </a>
    </article>
  </div>
</section>
