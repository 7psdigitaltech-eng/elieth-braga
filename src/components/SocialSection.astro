---
import SectionHeading from "./SectionHeading.astro";
import { siteContent } from "../content/site";

const socialCards = [
  {
    ...siteContent.socialSection.cards.instagram,
    url: siteContent.instagramUrl,
    icon: "instagram"
  },
  {
    ...siteContent.socialSection.cards.facebook,
    url: siteContent.facebookUrl,
    icon: "facebook"
  }
] as const;
---

<section class="page-section social-section" id="conteudos" aria-labelledby="conteudos-title">
  <div class="reveal">
    <SectionHeading
      eyebrow={siteContent.socialSection.eyebrow}
      title={siteContent.socialSection.title}
      id="conteudos-title"
      description={siteContent.socialSection.description}
    />
  </div>
  <div class="social-grid">
    {socialCards.map((card, index) => (
      <article class="social-card reveal" style={`--reveal-delay: ${index * 55}ms`}>
        <div class="social-card-header">
          <span class="social-icon" aria-hidden="true">
            {card.icon === "instagram" && (
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
                <rect x="5" y="5" width="14" height="14" rx="4"></rect>
                <circle cx="12" cy="12" r="3.2"></circle>
                <path d="M16.6 7.6h.01"></path>
              </svg>
            )}
            {card.icon === "facebook" && (
              <svg viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
                <path d="M14 8.5h2V5h-2.4A4.6 4.6 0 0 0 9 9.6V12H7v3.5h2V20h3.7v-4.5h2.5L15.8 12h-3.1V9.7c0-.7.5-1.2 1.3-1.2z"></path>
              </svg>
            )}
          </span>
          <span>{card.label}</span>
        </div>
        <div class="social-card-body">
          <h3>{card.title}</h3>
          <p>{card.text}</p>
        </div>
        <a
          class="button button-secondary"
          href={card.url}
          rel="noopener noreferrer"
          target="_blank"
          aria-label={card.ariaLabel}
        >
          {card.buttonLabel}
        </a>
      </article>
    ))}
  </div>
</section>
