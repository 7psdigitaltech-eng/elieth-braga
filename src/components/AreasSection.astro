---
import SectionHeading from "./SectionHeading.astro";
import { siteContent } from "../content/site";

const areaIconNames = ["book", "people", "building", "pin"] as const;
---

<section class="page-section areas-section" id="atuacao" aria-labelledby="atuacao-title">
  <div class="reveal">
    <SectionHeading
      eyebrow={siteContent.areas.eyebrow}
      title={siteContent.areas.title}
      id="atuacao-title"
      description={siteContent.areas.description}
    />
  </div>
  <div class="area-grid">
    {siteContent.areas.items.map((item, index) => (
      <article class="area-item reveal" style={`--reveal-delay: ${index * 55}ms`}>
        <div class="area-item-top">
          <span class="area-number">{item.number}</span>
          <span class="area-icon" aria-hidden="true">
            <svg class="area-icon-svg" viewBox="0 0 24 24" fill="none" aria-hidden="true" focusable="false">
              {areaIconNames[index] === "book" && (
                <>
                  <path d="M5 5.5h5.5A2.5 2.5 0 0 1 13 8v11a2.5 2.5 0 0 0-2.5-2.5H5z"></path>
                  <path d="M19 5.5h-5.5A2.5 2.5 0 0 0 11 8v11a2.5 2.5 0 0 1 2.5-2.5H19z"></path>
                </>
              )}
              {areaIconNames[index] === "people" && (
                <>
                  <circle cx="9" cy="9" r="2.5"></circle>
                  <circle cx="16" cy="10" r="2"></circle>
                  <path d="M4.5 18a4.5 4.5 0 0 1 9 0"></path>
                  <path d="M13.5 17.5a3.5 3.5 0 0 1 6 0"></path>
                </>
              )}
              {areaIconNames[index] === "building" && (
                <>
                  <path d="M5 20h14"></path>
                  <path d="M7 20V8l5-3 5 3v12"></path>
                  <path d="M10 11h.01"></path>
                  <path d="M14 11h.01"></path>
                  <path d="M10 15h.01"></path>
                  <path d="M14 15h.01"></path>
                </>
              )}
              {areaIconNames[index] === "pin" && (
                <>
                  <path d="M12 21s6-5.4 6-11a6 6 0 0 0-12 0c0 5.6 6 11 6 11z"></path>
                  <circle cx="12" cy="10" r="2"></circle>
                </>
              )}
            </svg>
          </span>
        </div>
        <h3>{item.title}</h3>
        <span class="area-rule" aria-hidden="true"></span>
        <p>{item.text}</p>
      </article>
    ))}
  </div>
</section>
