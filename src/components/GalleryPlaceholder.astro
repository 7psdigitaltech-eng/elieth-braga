---
import SectionHeading from "./SectionHeading.astro";
import { siteContent } from "../content/site";
---

<section class="page-section gallery-section" id="galeria" aria-labelledby="galeria-title">
  <div class="reveal">
    <SectionHeading
      eyebrow={siteContent.gallery.eyebrow}
      title={siteContent.gallery.title}
      id="galeria-title"
      description={siteContent.gallery.description}
    />
  </div>
  <div class="gallery-grid" aria-label="Registros autorizados da trajetória">
    {siteContent.gallery.items.map((item, index) => (
      <figure class="gallery-card reveal" style={`--reveal-delay: ${index * 55}ms`}>
        <img
          src={item.image.src}
          alt={item.image.alt}
          width={item.image.width}
          height={item.image.height}
          loading="lazy"
          decoding="async"
        />
        <figcaption>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </figcaption>
      </figure>
    ))}
  </div>
  <p class="section-note reveal">{siteContent.editorialNote}</p>
</section>
