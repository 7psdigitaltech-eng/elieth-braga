---
import SectionHeading from "./SectionHeading.astro";
import { siteContent } from "../content/site";
---

<section class="page-section gallery-section" id="galeria" aria-labelledby="galeria-title">
  <SectionHeading
    eyebrow={siteContent.gallery.eyebrow}
    title={siteContent.gallery.title}
    id="galeria-title"
    description={siteContent.gallery.description}
  />
  <div class="gallery-grid" aria-label="Registros autorizados da trajetória">
    {siteContent.gallery.items.map((item) => (
      <figure class="gallery-card">
        <img
          src={item.image.src}
          alt={item.image.alt}
          width={item.image.width}
          height={item.image.height}
          loading="lazy"
          decoding="async"
        />
        <figcaption>
          <h3>{item.title}</h3>
          <p>{item.text}</p>
        </figcaption>
      </figure>
    ))}
  </div>
  <p class="section-note">{siteContent.editorialNote}</p>
</section>
